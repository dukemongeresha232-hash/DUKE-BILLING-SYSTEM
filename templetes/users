<!DOCTYPE html>
<html>
<head>
    <title>Staff Management</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="container">
        <h1>👥 Staff Management</h1>
        <h3>Add Staff</h3>
        <form method="POST" action="/add-user">
            <input type="text" name="username" placeholder="Username" required>
            <input type="password" name="password" placeholder="Password" required>
            <input type="text" name="name" placeholder="Full Name" required>
            <input type="email" name="email" placeholder="Email" required>
            <select name="role">
                <option value="staff">Staff</option>
                <option value="admin">Admin</option>
            </select>
            <button type="submit" class="btn btn-primary">Add</button>
        </form>
        <h3>Staff List</h3>
        <table>
            <thead><tr><th>Username</th><th>Name</th><th>Role</th><th></th></tr></thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td>{{ user.username }}</td>
                    <td>{{ user.name }}</td>
                    <td>{{ user.role }}</td>
                    <td>{% if user.id != session.user_id %}<a href="/delete-staff/{{ user.id }}" class="btn-small btn-danger" onclick="return confirm('Delete?')">Delete</a>{% else %}<span class="badge">You</span>{% endif %}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <a href="/" class="btn">← Back</a>
    </div>
</body>
</html>
